# ============================================================
#  انسخ هذا الملف:   cp .env.example .env
#  ثم عدّل القيم قبل أول تشغيل
# ============================================================

# مفتاح تشفير الرسائل الخاصة (AES-256)
# شغّل:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MSG_SECRET=REPLACE_WITH_32_CHAR_HEX_KEY

# مفتاح توقيع JWT لجلسات المالك
# شغّل:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=REPLACE_WITH_ANOTHER_32_CHAR_HEX_KEY

# بورت السيرفر (اختياري)
PORT=3000
